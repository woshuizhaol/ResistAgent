rule data_audit:
    output:
        STAGE0["file_manifest"],
        STAGE0["data_audit"],
    threads: 1
    resources:
        gpu=0,
        mem_mb=2048,
    shell:
        f'"{PYTHON_BIN}" scripts/00_data_audit.py --config configs/base.yaml'


